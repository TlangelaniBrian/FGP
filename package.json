{
  "name": "first-gen-properties",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "npm --prefix apps/web run build",
    "test:api": "node scripts/api-smoke.mjs",
    "test:api:workflow": "node scripts/api-workflow-smoke.mjs",
    "test:auth-roles": "node scripts/auth-role-smoke.mjs",
    "test:capital-governance": "node scripts/capital-governance-smoke.mjs",
    "test:capital-governance:migration": "bash scripts/capital-governance-migration-replay.sh",
    "test:ui-foundation": "tsx scripts/ui-foundation-smoke.ts",
    "check:production": "node scripts/production-preflight.mjs",
    "migrate:production": "./scripts/migrate-production.sh",
    "typecheck": "pnpm --filter web run typecheck",
    "lint": "pnpm --filter web lint",
    "seed:zoning": "tsx scripts/seed/seed_zoning_rules.ts",
    "seed:tariffs": "tsx scripts/seed/seed_tariffs.ts",
    "seed:soshanguve": "tsx scripts/seed/seed_soshanguve.ts"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
